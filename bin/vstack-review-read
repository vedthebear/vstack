#!/usr/bin/env bash
# vstack-review-read — read review log and config for dashboard
# Usage: vstack-review-read
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
eval "$("$SCRIPT_DIR/vstack-slug" 2>/dev/null)"
VSTACK_HOME="${VSTACK_HOME:-$HOME/.vstack}"
cat "$VSTACK_HOME/projects/$SLUG/$BRANCH-reviews.jsonl" 2>/dev/null || echo "NO_REVIEWS"
echo "---CONFIG---"
"$SCRIPT_DIR/vstack-config" get skip_eng_review 2>/dev/null || echo "false"
echo "---HEAD---"
git rev-parse --short HEAD 2>/dev/null || echo "unknown"
